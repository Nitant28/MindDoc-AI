# OpenAI Configuration (Get from https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4-turbo

# JWT Security (Generate with: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=your-random-secret-key-min-32-chars

# Database Configuration
DATABASE_URL=sqlite:///minddoc.db

# Server Configuration
ENVIRONMENT=production
PORT=8000

# Optional: Ollama Local LLM (if self-hosting)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Deepseek API (alternative to OpenAI)
DEEPSEEK_API_KEY=your-deepseek-key-here

# Optional: Anthropic Claude
ANTHROPIC_API_KEY=your-claude-key-here
